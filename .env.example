# Environment
ENV_NAME=laptop
# laptop: WSL2 로컬 (RTX 4060, 코드 개발 + 가벼운 실행)
# desktop: 추가 데스크탑 (학습/추론 전용)
# colab: Google Colab (GPU 런타임)

# Device
DEVICE=auto
BATCH_SIZE=4
NUM_WORKERS=4

# Paths (환경별로 다름 — 각자 .env에서 설정)
DATA_IMAGE_DIR=
BITE_CHECKPOINT_DIR=
OUTPUT_DIR=./outputs

# BITE/SMAL
SMAL_MODEL_TYPE=39dogs_norm
BITE_APPLY_TTOPT=true
BITE_TTOPT_STEPS=301
